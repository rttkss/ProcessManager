<Window x:Class="ProcessManager.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Process Manager Pro" Height="850" Width="1400"
        WindowStartupLocation="CenterScreen"
        Background="#0F0F23"
        AllowsTransparency="True"
        WindowStyle="None"
        ResizeMode="CanResize">

    <Window.Resources>
        <!-- Градиенты -->
        <LinearGradientBrush x:Key="PrimaryGradient" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#667eea" Offset="0"/>
            <GradientStop Color="#764ba2" Offset="1"/>
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="AccentGradient" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#f093fb" Offset="0"/>
            <GradientStop Color="#f5576c" Offset="1"/>
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="SuccessGradient" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#4facfe" Offset="0"/>
            <GradientStop Color="#00f2fe" Offset="1"/>
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="DangerGradient" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#fa709a" Offset="0"/>
            <GradientStop Color="#fee140" Offset="1"/>
        </LinearGradientBrush>

        <!-- Эффекты тени -->
        <DropShadowEffect x:Key="SoftShadow" 
                          Color="#000000" 
                          BlurRadius="20" 
                          ShadowDepth="5" 
                          Opacity="0.3" 
                          Direction="270"/>

        <DropShadowEffect x:Key="GlowEffect" 
                          Color="#667eea" 
                          BlurRadius="15" 
                          ShadowDepth="0" 
                          Opacity="0.6"/>

        <!-- Стиль кнопок -->
        <Style x:Key="ModernButton" TargetType="Button">
            <Setter Property="Background" Value="#1a1a2e"/>
            <Setter Property="Foreground" Value="#ffffff"/>
            <Setter Property="BorderBrush" Value="#667eea"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="Padding" Value="20,10"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Effect" Value="{StaticResource SoftShadow}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="12"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#252544"/>
                                <Setter Property="Effect" Value="{StaticResource GlowEffect}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#2d2d4a"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="GradientButton" TargetType="Button" BasedOn="{StaticResource ModernButton}">
            <Setter Property="Background" Value="{StaticResource PrimaryGradient}"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>

        <Style x:Key="DangerButton" TargetType="Button" BasedOn="{StaticResource ModernButton}">
            <Setter Property="Background" Value="{StaticResource DangerGradient}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="#1a1a2e"/>
            <Setter Property="FontWeight" Value="Bold"/>
        </Style>

        <Style x:Key="SuccessButton" TargetType="Button" BasedOn="{StaticResource ModernButton}">
            <Setter Property="Background" Value="{StaticResource SuccessGradient}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="#ffffff"/>
        </Style>

        <!-- Стиль DataGrid -->
        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="#1a1a2e"/>
            <Setter Property="Foreground" Value="#e0e0e0"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="RowBackground" Value="#1a1a2e"/>
            <Setter Property="AlternatingRowBackground" Value="#16162a"/>
            <Setter Property="HorizontalGridLinesBrush" Value="#2d2d4a"/>
            <Setter Property="VerticalGridLinesBrush" Value="#2d2d4a"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="SelectionMode" Value="Single"/>
            <Setter Property="CanUserAddRows" Value="False"/>
            <Setter Property="CanUserDeleteRows" Value="False"/>
            <Setter Property="GridLinesVisibility" Value="Horizontal"/>
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="{StaticResource PrimaryGradient}"/>
            <Setter Property="Foreground" Value="#ffffff"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
        </Style>

        <Style TargetType="DataGridRow">
            <Setter Property="Background" Value="Transparent"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background">
                        <Setter.Value>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="#667eea" Offset="0"/>
                                <GradientStop Color="#764ba2" Offset="1"/>
                            </LinearGradientBrush>
                        </Setter.Value>
                    </Setter>
                    <Setter Property="Foreground" Value="#ffffff"/>
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#252544"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="DataGridCell">
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="Foreground" Value="#e0e0e0"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="Foreground" Value="#ffffff"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Стиль CheckBox -->
        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="#e0e0e0"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Margin" Value="8,4"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <StackPanel Orientation="Horizontal">
                            <Border x:Name="checkBorder"
                                    Width="22" Height="22"
                                    Background="#1a1a2e"
                                    BorderBrush="#667eea"
                                    BorderThickness="2"
                                    CornerRadius="6"
                                    Margin="0,0,8,0">
                                <Path x:Name="checkMark"
                                      Data="M 2,6 L 8,12 L 18,2"
                                      Stroke="#667eea"
                                      StrokeThickness="3"
                                      Visibility="Collapsed"
                                      Stretch="Uniform"
                                      Margin="3"/>
                            </Border>
                            <ContentPresenter VerticalAlignment="Center"/>
                        </StackPanel>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="checkMark" Property="Visibility" Value="Visible"/>
                                <Setter TargetName="checkBorder" Property="Background" Value="{StaticResource PrimaryGradient}"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="checkBorder" Property="BorderBrush" Value="#764ba2"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Стиль Label -->
        <Style TargetType="Label">
            <Setter Property="Foreground" Value="#a0a0c0"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="0"/>
        </Style>

        <!-- Стиль TabControl -->
        <Style TargetType="TabControl">
            <Setter Property="Background" Value="#1a1a2e"/>
            <Setter Property="BorderBrush" Value="#667eea"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="Effect" Value="{StaticResource SoftShadow}"/>
        </Style>

        <Style TargetType="TabItem">
            <Setter Property="Background" Value="#16162a"/>
            <Setter Property="Foreground" Value="#a0a0c0"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="20,10"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="0,0,0,3"
                                CornerRadius="8,8,0,0"
                                Padding="{TemplateBinding Padding}"
                                Margin="2,0">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                            ContentSource="Header"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#1a1a2e"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="{StaticResource PrimaryGradient}"/>
                                <Setter Property="Foreground" Value="#ffffff"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="#e0e0e0"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Стиль TreeView -->
        <Style TargetType="TreeView">
            <Setter Property="Background" Value="#1a1a2e"/>
            <Setter Property="Foreground" Value="#e0e0e0"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>

        <Style TargetType="TreeViewItem">
            <Setter Property="Foreground" Value="#e0e0e0"/>
            <Setter Property="Padding" Value="4"/>
        </Style>
    </Window.Resources>

    <Border Background="#0F0F23" CornerRadius="15" BorderBrush="{StaticResource PrimaryGradient}" BorderThickness="2">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="60"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="35"/>
            </Grid.RowDefinitions>

            <!-- HEADER С ГРАДИЕНТОМ -->
            <Border Grid.Row="0" Background="{StaticResource PrimaryGradient}" CornerRadius="13,13,0,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Логотип и заголовок -->
                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="25,0">
                        <Ellipse Width="40" Height="40" Fill="#ffffff" Opacity="0.2" Margin="0,0,15,0"/>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="PROCESS MANAGER" FontSize="18" FontWeight="Bold"
                                       Foreground="#ffffff" FontFamily="Segoe UI"/>
                            <TextBlock Text="Advanced System Monitor" FontSize="11"
                                       Foreground="#e0e0e0" FontFamily="Segoe UI" Opacity="0.8"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- ПРОСТОЕ ПОЛЕ ПОИСКА (БЕЗ СТИЛЕЙ) -->
                    <StackPanel Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Center">
                        <TextBlock Text="🔍 Поиск процессов:" Foreground="#ffffff" FontSize="11" 
                                   Margin="0,0,0,4" FontFamily="Segoe UI"/>
                        <TextBox x:Name="SearchBox" 
                                 Width="380" 
                                 Height="32"
                                 Background="White"
                                 Foreground="Black"
                                 FontSize="14"
                                 FontFamily="Segoe UI"
                                 Padding="8,5"
                                 BorderBrush="#667eea"
                                 BorderThickness="2"
                                 TextChanged="SearchBox_TextChanged"
                                 ToolTip="Введите имя процесса для поиска"/>
                    </StackPanel>

                    <!-- Кнопки управления -->
                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,25,0">
                        <TextBlock x:Name="ClockText" FontSize="14" Foreground="#ffffff"
                                   FontFamily="Consolas" VerticalAlignment="Center" Margin="0,0,20,0" FontWeight="Bold"/>
                        <Button Content="🔄 Обновить" Style="{StaticResource SuccessButton}"
                                Click="Refresh_Click" Height="38" Margin="0,0,10,0"/>
                        <Button x:Name="AutoRefreshBtn" Content="⚡ Auto: OFF" Style="{StaticResource ModernButton}"
                                Click="AutoRefresh_Click" Height="38" Margin="0,0,10,0"/>
                        <Button Content="✕" Width="38" Height="38" 
                                Background="#ff4757" BorderThickness="0" 
                                FontSize="18" FontWeight="Bold" Foreground="#ffffff"
                                Click="CloseButton_Click" Cursor="Hand">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}" CornerRadius="10">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </Button.Style>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ОСНОВНОЙ КОНТЕНТ -->
            <Grid Grid.Row="1" Margin="15">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2.5*"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- ЛЕВАЯ ПАНЕЛЬ: Список процессов -->
                <Grid Grid.Column="0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Фильтры -->
                    <Border Grid.Row="0" Background="#1a1a2e" BorderBrush="#667eea"
                            BorderThickness="2" CornerRadius="12" Padding="15,12" Margin="0,0,0,10"
                            Effect="{StaticResource SoftShadow}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="⚙️" FontSize="16" VerticalAlignment="Center" Margin="0,0,10,0"/>
                            <Label Content="Фильтры:" VerticalAlignment="Center" Margin="0,0,15,0" FontWeight="SemiBold"/>
                            <CheckBox x:Name="FilterGuiOnly" Content="Только с GUI"
                                      Checked="Filter_Changed" Unchecked="Filter_Changed"/>
                            <CheckBox x:Name="FilterSystemOnly" Content="Системные процессы" Margin="20,0,0,0"
                                      Checked="Filter_Changed" Unchecked="Filter_Changed"/>
                            <Rectangle Width="2" Fill="#667eea" Margin="20,0"/>
                            <Label Content="📊 Всего процессов:" VerticalAlignment="Center" FontWeight="SemiBold"/>
                            <TextBlock x:Name="ProcessCountLabel" Foreground="#4facfe"
                                       VerticalAlignment="Center" FontFamily="Consolas" FontSize="14" Margin="8,0" FontWeight="Bold"/>
                        </StackPanel>
                    </Border>

                    <!-- Таблица процессов -->
                    <Border Grid.Row="1" 
                            Background="#1a1a2e" 
                            BorderBrush="#667eea"
                            BorderThickness="2" 
                            CornerRadius="12"
                            Effect="{StaticResource SoftShadow}">
                        <DataGrid x:Name="ProcessGrid"
                                  SelectionChanged="ProcessGrid_SelectionChanged"
                                  Sorting="ProcessGrid_Sorting"
                                  IsReadOnly="True"
                                  Background="Transparent"
                                  BorderThickness="0">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="PID" Binding="{Binding Id}" Width="80"/>
                                <DataGridTextColumn Header="Процесс" Binding="{Binding Name}" Width="200"/>
                                <DataGridTextColumn Header="Приоритет" Binding="{Binding Priority}" Width="120"/>
                                <DataGridTextColumn Header="Потоки" Binding="{Binding ThreadCount}" Width="80"/>
                                <DataGridTextColumn Header="Память" Binding="{Binding MemoryUsageMb}" Width="110"/>
                                <DataGridTextColumn Header="CPU Time" Binding="{Binding CpuTimeStr}" Width="120"/>
                                <DataGridTextColumn Header="Старт" Binding="{Binding StartTimeStr}" Width="*"/>
                            </DataGrid.Columns>
                            <DataGrid.RowStyle>
                                <Style TargetType="DataGridRow">
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsHighPriority}" Value="True">
                                            <Setter Property="Background">
                                                <Setter.Value>
                                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                        <GradientStop Color="#fa709a" Offset="0"/>
                                                        <GradientStop Color="#fee140" Offset="0.5"/>
                                                    </LinearGradientBrush>
                                                </Setter.Value>
                                            </Setter>
                                            <Setter Property="Foreground" Value="#1a1a2e"/>
                                            <Setter Property="FontWeight" Value="Bold"/>
                                        </DataTrigger>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter Property="Background" Value="{StaticResource PrimaryGradient}"/>
                                            <Setter Property="Foreground" Value="#ffffff"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </DataGrid.RowStyle>
                        </DataGrid>
                    </Border>

                    <!-- Панель действий -->
                    <Border Grid.Row="2" Background="#1a1a2e" BorderBrush="#667eea"
                            BorderThickness="2" CornerRadius="12" Padding="15,12" Margin="0,10,0,0"
                            Effect="{StaticResource SoftShadow}">
                        <StackPanel Orientation="Horizontal">
                            <Button Content="❌ Завершить процесс" Style="{StaticResource DangerButton}"
                                    Click="Kill_Click" Height="40" Margin="0,0,15,0"/>
                            <Rectangle Width="2" Fill="#667eea" Margin="10,0"/>
                            <Label Content="⚡ Приоритет:" VerticalAlignment="Center" Margin="15,0,10,0" FontWeight="SemiBold"/>

                            <!-- ПРОСТОЙ ComboBox БЕЗ СТИЛЕЙ -->
                            <ComboBox x:Name="PriorityBox" 
                                      Width="160" 
                                      Height="40" 
                                      Margin="0,0,15,0"
                                      Background="White"
                                      Foreground="Black"
                                      FontSize="13"
                                      FontWeight="Bold"
                                      FontFamily="Segoe UI">
                                <ComboBoxItem Content="Idle"/>
                                <ComboBoxItem Content="BelowNormal"/>
                                <ComboBoxItem Content="Normal" IsSelected="True"/>
                                <ComboBoxItem Content="AboveNormal"/>
                                <ComboBoxItem Content="High"/>
                                <ComboBoxItem Content="RealTime"/>
                            </ComboBox>

                            <Button Content="✓ Применить" Style="{StaticResource GradientButton}"
                                    Click="SetPriority_Click" Height="40"/>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- Разделитель -->
                <Rectangle Grid.Column="1" Fill="{StaticResource PrimaryGradient}" RadiusX="3" RadiusY="3" Margin="0,10"/>

                <!-- ПРАВАЯ ПАНЕЛЬ: Детали -->
                <TabControl Grid.Column="2">

                    <TabItem Header="🧵 Потоки">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <Border Grid.Row="0" Background="#16162a" Padding="12,10">
                                <StackPanel Orientation="Horizontal">
                                    <Button Content="📋 Показать потоки" Style="{StaticResource GradientButton}"
                                            Click="Threads_Click" Height="36" Margin="0,0,12,0"/>
                                    <TextBlock x:Name="ThreadCountLabel" Foreground="#4facfe"
                                               VerticalAlignment="Center" FontFamily="Consolas" FontSize="13" FontWeight="Bold"/>
                                </StackPanel>
                            </Border>
                            <DataGrid x:Name="ThreadGrid" Grid.Row="1" IsReadOnly="True">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="90"/>
                                    <DataGridTextColumn Header="Приоритет" Binding="{Binding Priority}" Width="100"/>
                                    <DataGridTextColumn Header="Состояние" Binding="{Binding State}" Width="100"/>
                                    <DataGridTextColumn Header="Wait Reason" Binding="{Binding WaitReason}" Width="*"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Grid>
                    </TabItem>

                    <TabItem Header="🎯 CPU Affinity">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel Margin="20">
                                <TextBlock Text="⚙️ CPU Affinity Control" FontSize="16"
                                           FontWeight="Bold" Foreground="#ffffff"
                                           FontFamily="Segoe UI" Margin="0,0,0,10"/>
                                <TextBlock Text="Выберите процессорные ядра для выполнения процесса:"
                                           Foreground="#a0a0c0" FontSize="12" FontFamily="Segoe UI" Margin="0,0,0,15"
                                           TextWrapping="Wrap"/>

                                <Border Background="#16162a" BorderBrush="#667eea"
                                        BorderThickness="2" CornerRadius="12" Padding="15" Margin="0,0,0,15">
                                    <WrapPanel x:Name="CpuCoresPanel"/>
                                </Border>

                                <Grid Margin="0,0,0,15">
                                    <Grid.RowDefinitions>
                                        <RowDefinition/>
                                        <RowDefinition Height="10"/>
                                        <RowDefinition/>
                                    </Grid.RowDefinitions>

                                    <Border Grid.Row="0" Background="#16162a" BorderBrush="{StaticResource SuccessGradient}"
                                            BorderThickness="2" CornerRadius="12" Padding="12">
                                        <StackPanel>
                                            <TextBlock Text="💾 BIN маска" Foreground="#a0a0c0" FontSize="11" FontFamily="Segoe UI"/>
                                            <TextBlock x:Name="BinMaskLabel" Foreground="#4facfe"
                                                       FontFamily="Consolas" FontSize="13" TextWrapping="Wrap" FontWeight="Bold"/>
                                        </StackPanel>
                                    </Border>

                                    <Border Grid.Row="2" Background="#16162a" BorderBrush="{StaticResource AccentGradient}"
                                            BorderThickness="2" CornerRadius="12" Padding="12">
                                        <StackPanel>
                                            <TextBlock Text="🔢 HEX маска" Foreground="#a0a0c0" FontSize="11" FontFamily="Segoe UI"/>
                                            <TextBlock x:Name="HexMaskLabel" Foreground="#f093fb"
                                                       FontFamily="Consolas" FontSize="13" FontWeight="Bold"/>
                                        </StackPanel>
                                    </Border>
                                </Grid>

                                <Button Content="✓ Применить CPU Affinity" Style="{StaticResource GradientButton}"
                                        Click="SetAffinity_Click" Height="45" HorizontalAlignment="Stretch" FontSize="14"/>
                            </StackPanel>
                        </ScrollViewer>
                    </TabItem>

                    <TabItem Header="🌳 Дерево">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <Border Grid.Row="0" Background="#16162a" Padding="12,10">
                                <Button Content="🌲 Построить дерево процессов" Style="{StaticResource GradientButton}"
                                        Click="BuildTree_Click" Height="36"/>
                            </Border>
                            <TreeView x:Name="ProcessTree" Grid.Row="1" Padding="10"/>
                        </Grid>
                    </TabItem>

                    <TabItem Header="ℹ️ Info">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel x:Name="ProcessInfoPanel" Margin="20"/>
                        </ScrollViewer>
                    </TabItem>

                </TabControl>
            </Grid>

            <!-- STATUS BAR С ГРАДИЕНТОМ -->
            <Border Grid.Row="2" Background="{StaticResource PrimaryGradient}" CornerRadius="0,0,13,13">
                <Grid Margin="15,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock x:Name="StatusLabel" Grid.Column="0" Foreground="#ffffff"
                               FontFamily="Segoe UI" FontSize="12" VerticalAlignment="Center" FontWeight="SemiBold"/>
                    <TextBlock x:Name="CpuLabel" Grid.Column="1" Foreground="#ffffff"
                               FontFamily="Consolas" FontSize="12" VerticalAlignment="Center" Margin="0,0,20,0" FontWeight="Bold"/>
                    <TextBlock x:Name="RamLabel" Grid.Column="2" Foreground="#ffffff"
                               FontFamily="Consolas" FontSize="12" VerticalAlignment="Center" Margin="0,0,10,0" FontWeight="Bold"/>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>